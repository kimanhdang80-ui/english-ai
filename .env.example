# =========================================================================
# English AI — Environment Variables (template)
# Copy to `.env` (and `.env.local` for Next.js runtime) and fill in real values.
# NEVER commit real secrets. See docs/CLAUDE.md §9 (Security Rules).
# =========================================================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="English AI"

# --- Database (PostgreSQL / Prisma) ---
# Local docker-compose default matches docker-compose.yml
DATABASE_URL="postgresql://englishai:englishai@localhost:5432/englishai?schema=public"
# DIRECT_URL is REQUIRED (the schema references it). It is the direct, non-pooled
# connection used by `prisma migrate deploy`/introspection.
#  - Local / no pooler: set it EQUAL to DATABASE_URL (as below).
#  - Supabase production: DATABASE_URL = pooled URL (port 6543, ?pgbouncer=true),
#    DIRECT_URL = direct URL (port 5432). See VERCEL_DEPLOY.md.
DIRECT_URL="postgresql://englishai:englishai@localhost:5432/englishai?schema=public"

# --- Supabase Auth ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only key — never exposed to the client
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- AI Providers (server-only; NEVER expose to the client) ---
# Which provider to use: "anthropic" (default) or "openai". See docs/AI_INTEGRATION_GUIDE.md.
AI_PROVIDER="anthropic"
# Optional automatic fallback if the primary provider fails: "anthropic" | "openai" | "none".
AI_FALLBACK_PROVIDER="none"
# API keys — fill only the provider(s) you use. Leave blank to run with the safe
# rule-based fallback (the learning loop still works without AI).
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
# Optional default-model override; otherwise src/modules/ai/config/models.ts applies.
# AI_DEFAULT_MODEL="claude-sonnet-4-6"
# Resilience: per-call timeout (ms) and retry attempts on transient errors.
AI_TIMEOUT_MS="20000"
AI_MAX_RETRIES="2"
# Circuit breaker: consecutive failures that open it, and the cooldown before a retry.
AI_CIRCUIT_FAILURE_THRESHOLD="5"
AI_CIRCUIT_COOLDOWN_MS="30000"
